#!/usr/bin/env python3
# sysknife-apt-pin-edit — write/remove an apt pin drop-in under
# /etc/apt/preferences.d/.
#
# Install to: /usr/lib/sysknife/apt-pin-edit
# Mode:       0755
# Owner:      root:root
#
# Invoked exclusively by the sysknife-daemon via:
#   sudo /usr/lib/sysknife/apt-pin-edit --op set --name <name> \
#        --package <glob> --pin <expr> --priority <int>
#   sudo /usr/lib/sysknife/apt-pin-edit --op remove --name <name>
#
# Inputs are re-validated here (defense-in-depth):
#   - name: ^[a-z0-9][a-z0-9_-]{0,63}$ — no dots (apt ignores preferences.d
#     files whose names contain a dot unless the extension is `.pref`; we use
#     no extension, so a dotted name would silently not apply). File lands at
#     /etc/apt/preferences.d/sysknife-<name>.
#   - package: an apt package-name glob ([A-Za-z0-9.+*?_:-]).
#   - pin: an apt Pin expression (e.g. `release a=noble-security`,
#     `version 1.2.*`, `origin repo.example.com`); no control characters.
#   - priority: integer in [-1, 1000].

import argparse
import os
import re
import sys
import tempfile

PREFS_D = "/etc/apt/preferences.d"
PREFIX = "sysknife-"

NAME_RE = re.compile(r"^[a-z0-9][a-z0-9_-]{0,63}$")
PACKAGE_RE = re.compile(r"^[A-Za-z0-9.+*?_:-]{1,128}$")
PIN_RE = re.compile(r"^[A-Za-z0-9 =.,:/*_+-]{1,200}$")


def die(msg: str) -> None:
    print(f"sysknife-apt-pin-edit: {msg}", file=sys.stderr)
    sys.exit(1)


def op_set(args) -> None:
    if not NAME_RE.match(args.name):
        die(f"invalid name {args.name!r}")
    if not PACKAGE_RE.match(args.package):
        die(f"invalid package glob {args.package!r}")
    if not PIN_RE.match(args.pin):
        die(f"invalid pin expression {args.pin!r}")
    if args.priority < -1 or args.priority > 1000:
        die("priority out of range [-1, 1000]")

    content = (
        f"# Managed by SysKnife (set_apt_pin: {args.name}). Do not edit by hand.\n"
        f"Package: {args.package}\n"
        f"Pin: {args.pin}\n"
        f"Pin-Priority: {args.priority}\n"
    )
    dest = os.path.join(PREFS_D, PREFIX + args.name)
    try:
        os.makedirs(PREFS_D, exist_ok=True)
        fd, tmp = tempfile.mkstemp(dir=PREFS_D, prefix=".sysknife-pin-")
        with os.fdopen(fd, "w") as fh:
            fh.write(content)
        os.chmod(tmp, 0o644)
        os.replace(tmp, dest)
    except OSError as exc:
        die(f"cannot write pin: {exc}")


def op_remove(args) -> None:
    if not NAME_RE.match(args.name):
        die(f"invalid name {args.name!r}")
    dest = os.path.join(PREFS_D, PREFIX + args.name)
    if os.path.exists(dest):
        try:
            os.unlink(dest)
        except OSError as exc:
            die(f"cannot remove pin: {exc}")


def main() -> None:
    parser = argparse.ArgumentParser(description="Manage apt preferences.d pins.")
    parser.add_argument("--op", required=True, choices=["set", "remove"])
    parser.add_argument("--name", required=True)
    parser.add_argument("--package")
    parser.add_argument("--pin")
    parser.add_argument("--priority", type=int)
    args = parser.parse_args()

    if args.op == "set":
        if not (args.package and args.pin is not None and args.priority is not None):
            die("set requires --package, --pin, --priority")
        op_set(args)
    else:
        op_remove(args)


if __name__ == "__main__":
    main()
